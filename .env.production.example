# ============================================
# 生产环境环境变量配置
# 复制此文件为 .env 并根据实际情况修改
# ============================================

# ============================================
# 数据库配置（务必修改密码）
# ============================================
MYSQL_ROOT_PASSWORD=YourSecureRootPassword123!
DB_HOST=mysql
DB_PORT=3306
DB_USER=blog
DB_PASSWORD=YourSecureDBPassword123!
DB_NAME=personal_blog

# ============================================
# Redis 配置（务必修改密码）
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YourSecureRedisPassword123!

# ============================================
# JWT 配置（务必修改，至少 32 位随机字符串）
# 可使用: openssl rand -base64 32
# ============================================
JWT_SECRET=YourSuperSecretJWTKeyChangeThisImmediately123!
JWT_EXPIRES_IN=7d

# ============================================
# 服务端口配置
# ============================================
BACKEND_PORT=3001
FRONTEND_PORT=80
ADMIN_PORT=8080
HTTPS_PORT=443

# ============================================
# 时区配置
# ============================================
TZ=Asia/Shanghai

# ============================================
# 其他配置
# ============================================
NODE_ENV=production
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
